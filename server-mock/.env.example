# Configuracion del Plan B (json-server, sin MongoDB).
# Copia este archivo a .env si queres cambiar los valores por defecto.

# Misma clave que usa el backend de Mongo (server/.env). Asi los tokens
# firmados por un backend son aceptados por el otro — util para alternar
# sin tener que reloguear.
JWT_SECRET=libraryhub_dev_secret_key

# Puerto del Plan B. Distinto al backend de Mongo (5000) para poder correr
# ambos al mismo tiempo si se quiere.
PORT=5001
