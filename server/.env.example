# Ejemplo de variables de entorno del backend.
# Copiar este archivo a .env y completar los valores antes de iniciar el servidor.

# Cadena de conexion a MongoDB (local en este caso).
MONGODB_URI=mongodb://localhost:27017/libraryhub

# Clave secreta usada para firmar los tokens JWT.
# En produccion reemplazar por una clave larga y aleatoria.
JWT_SECRET=reemplazar_este_valor_por_una_clave_larga_y_aleatoria

# Puerto donde escucha el servidor Express.
PORT=5000
