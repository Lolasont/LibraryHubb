# Configuracion del frontend.
# VITE_API_URL apunta a la API del backend de LibraryHub.
#
# Para alternar entre backends, descomentar la linea correspondiente y
# reiniciar `npm run dev` para que Vite tome el nuevo valor.
#
# Backend oficial (Express + MongoDB, server/):
#VITE_API_URL=http://localhost:5000/api
#
# Plan B (json-server + db.json, server-mock/):
#VITE_API_URL=http://localhost:5001/api
